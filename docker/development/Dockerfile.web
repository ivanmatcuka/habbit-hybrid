FROM node:22.13 AS deploy

ARG LIB_GIT_SOURCE
ARG LIB_PROJECT_NAME
ARG PROJECT_NAME

WORKDIR /usr/src/app/$PROJECT_NAME

COPY ./package*.json ./
COPY . ./

RUN npm install
RUN npm i $LIB_GIT_SOURCE#development

# temp


RUN git clone $LIB_GIT_SOURCE ../$LIB_PROJECT_NAME
WORKDIR /usr/src/app/$LIB_PROJECT_NAME
RUN npm i
RUN npm run build:library
WORKDIR /usr/src/app/$PROJECT_NAME
RUN npm i ../$LIB_PROJECT_NAME

RUN npm run build:development
RUN npx cap sync web

EXPOSE 4174
CMD [ "npm", "run", "host:development" ]