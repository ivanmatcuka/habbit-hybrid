{
  "name": "habits-hybrid",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc && vite build",
    "preview": "vite preview",
    "test:e2e": "cypress run",
    "test:unit": "vitest",
    "lint": "eslint .",
    "dev:ios": "ionic capacitor run ios --livereload --external",
    "dev:android": "ionic capacitor run android --livereload --external",
    "build:development": "vue-tsc && vite build --mode development",
    "host:development": "vite dev --host --port 4174",
    "android:debug": "cd android && ./gradlew assembleDebug && cd ..",
    "ios:debug": "cd ios/App && fastlane development && xcodebuild build-for-testing -workspace App.xcworkspace -scheme App -destination generic/platform=iOS && cd ../.."
  },
  "dependencies": {
    "@capacitor/android": "^5.7.8",
    "@capacitor/app": "^5.0.8",
    "@capacitor/core": "^5.7.8",
    "@capacitor/haptics": "^5.0.8",
    "@capacitor/ios": "^5.7.8",
    "@capacitor/keyboard": "^5.0.9",
    "@capacitor/status-bar": "^5.0.8",
    "@ionic/vue": "^8.0.0",
    "@ionic/vue-router": "^8.0.0",
    "bootstrap": "^5.3.7",
    "bootstrap-vue-next": "^0.30.4",
    "habits-frontend": "file:../habits-frontend",
    "ionicons": "^7.0.0",
    "pinia": "^3.0.4",
    "vue": "^3.5.18",
    "vue-router": "^4.2.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^5.7.8",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vue/eslint-config-typescript": "^14.6.0",
    "@vue/test-utils": "^2.3.0",
    "cypress": "^13.5.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-css-reorder": "^0.5.1",
    "eslint-plugin-perfectionist": "^4.15.0",
    "eslint-plugin-vue": "^9.9.0",
    "jiti": "^2.6.1",
    "jsdom": "^22.1.0",
    "prettier-eslint": "^16.4.2",
    "prettier-plugin-css-order": "^2.2.0",
    "sass": "^1.77.6",
    "storybook-dark-mode": "^5.0.0",
    "terser": "^5.4.0",
    "typescript": "~5.8.0",
    "unplugin-icons": "^22.2.0",
    "unplugin-vue-components": "^28.8.0",
    "vite": "5.0.0",
    "vitest": "^0.34.6",
    "vue-tsc": "^3.0.4"
  },
  "peerDependencies": {
    "@vue/tsconfig": "^0.7.0",
    "axios": "^1.16.1",
    "moment": "^2.30.1",
    "vite-plugin-vue-devtools": "7.0.0",
    "vue": "^3.5.18"
  },
  "description": "App for Habits"
}
