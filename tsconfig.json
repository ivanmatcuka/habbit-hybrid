{
  "compilerOptions": {
    "target": "ESNext",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "jsx": "preserve",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "lib": ["ESNext", "DOM"],
    "skipLibCheck": true,
    "noEmit": true,
    "paths": {
      "@/*": ["./src/*"],
      "~shared/pages/*": ["../habbit-frontend/src/pages/*"],
      "~shared/components/*": ["../habbit-frontend/src/components/*"],
      "~shared/icons/*": ["../habbit-frontend/src/icons/*"],
      "~shared/services/*": ["../habbit-frontend/src/services/*"],
      "~shared/utils/*": ["../habbit-frontend/src/utils/*"],
      "~shared/stores/*": ["../habbit-frontend/src/stores/*"],
      "~shared/stores": ["../habbit-frontend/src/stores"],
      "~shared/UnauthLayout.vue": ["../habbit-frontend/src/UnauthLayout.vue"]
    }
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.d.ts",
    "src/**/*.tsx",
    "src/**/*.vue",
    "vue-shim.d.ts",
    "env.d.ts"
  ],
  "references": [{ "path": "./tsconfig.node.json" }]
}
